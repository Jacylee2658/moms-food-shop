<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Mama Jude\'s Food Shop' %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Header -->
    <div class="header">
        <h1>🍲 Mama Jude's Food Shop</h1>
        <p>Authentic Nigerian Foodstuffs - Fresh & Quality Guaranteed</p>
    </div>
    
    <!-- Navigation -->
    <div class="nav">
        <div class="nav-container">
            <button class="menu-btn" id="menuBtn">☰</button>
            <ul class="nav-links" id="navLinks">
                <li><a href="/" class="<%= !categoryId ? 'active' : '' %>">All Products</a></li>
                <% categories.forEach(category => { %>
                    <li><a href="/category/<%= category.id %>" class="<%= categoryId == category.id ? 'active' : '' %>">
                        <%= category.name %>
                    </a></li>
                <% }) %>
            </ul>
            <div class="cart-icon" onclick="openCart()">
                🛒
                <span class="cart-count">0</span>
            </div>
        </div>
    </div>
    
    <!-- Hero Section -->
    <div class="container">
        <div class="hero">
            <h2>Fresh Nigerian Foodstuffs</h2>
            <p>Shop from Mama Jude's collection of authentic ingredients<br>For all your traditional cooking needs</p>
            <a href="#products" class="hero-btn">Shop Now</a>
        </div>
    </div>
    
    <!-- Products Section -->
    <div class="container" id="products">
        <div class="products">
            <% if (products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="product-card">
                        <div class="product-image">
                            <% if (product.image_url) { %>
                                <img src="<%= product.image_url %>" alt="<%= product.name %>" style="width:100%; height:100%; object-fit:cover;">
                            <% } else { %>
                                <span style="font-size: 4rem;">
                                    <% if (product.name.includes('Egusi')) { %>🥜
                                    <% } else if (product.name.includes('Ogbono')) { %>🌰
                                    <% } else if (product.name.includes('Ugu')) { %>🥬
                                    <% } else if (product.name.includes('Garri')) { %>🍚
                                    <% } else if (product.name.includes('Palm Oil')) { %>🟠
                                    <% } else if (product.name.includes('Crayfish')) { %>🦐
                                    <% } else { %>🍽️
                                    <% } %>
                                </span>
                            <% } %>
                            <div class="product-badge">Popular</div>
                        </div>
                        <div class="product-info">
                            <div class="product-name"><%= product.name %></div>
                            <div class="product-category"><%= product.category_name %></div>
                            <div class="product-price">₦<%= product.price.toLocaleString() %></div>
                            <div class="product-unit">per <%= product.unit %></div>
                            <div class="product-stock <%= product.stock_quantity > 10 ? 'in-stock' : 'low-stock' %>">
                                <%= product.stock_quantity > 0 ? `${product.stock_quantity} in stock` : 'Out of stock' %>
                            </div>
                            <button class="btn" onclick="addToCart(<%= product.id %>, '<%= product.name %>', <%= product.price %>)">
                                Add to Cart 🛒
                            </button>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="text-align:center; grid-column:1/-1;">No products found in this category.</p>
            <% } %>
        </div>
    </div>
    
    <!-- Cart Sidebar -->
    <div class="cart-sidebar" id="cartSidebar">
        <div class="cart-header">
            <h3>Your Cart 🛒</h3>
            <button onclick="closeCart()">✕</button>
        </div>
        <div class="cart-items" id="cartItems">
            <p style="text-align:center; padding:2rem;">Your cart is empty</p>
        </div>
        <div class="cart-footer">
            <div class="cart-total">
                Total: <span id="cartTotal">₦0</span>
            </div>
            <button class="checkout-btn" onclick="checkout()">Proceed to Checkout</button>
        </div>
    </div>
    
    <!-- Overlay -->
    <div class="overlay" id="overlay"></div>
    
    <!-- Notification -->
    <div id="notification" style="position: fixed; bottom: 20px; right: 20px; background: #4caf50; color: white; padding: 1rem; border-radius: 8px; display: none; z-index: 1001;">
        Item added to cart!
    </div>
    
    <!-- Footer -->
    <div class="footer">
        <p>🍲 Mama Jude's Food Shop</p>
        <p>📍 Available for pickup at: 3, Abass Amoo Street, Orimerumu, Ogun State.</p>
        <p>📞 Call to order: 070-614-37700, 080-591-66359</p>
        <p>⏰ Pickup hours: Monday - Saturday, 8am - 10pm</p>
        <p>&copy; 2026 Mama Jude's Food Shop. All rights reserved.</p>
    </div>
    
    <script src="/js/main.js"></script>
    <style>
        #notification.show {
            display: block !important;
            animation: slideIn 0.3s ease;
        }
        
        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
</body>
</html>