<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .admin-container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 1rem;
        }
        .admin-nav {
            background: #333;
            padding: 1rem;
            margin-bottom: 2rem;
        }
        .admin-nav a {
            color: white;
            margin-right: 1rem;
            text-decoration: none;
        }
        .section {
            background: white;
            padding: 1.5rem;
            margin-bottom: 2rem;
            border-radius: 10px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            padding: 0.75rem;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }
        .status-badge {
            padding: 0.25rem 0.5rem;
            border-radius: 5px;
            font-size: 0.8rem;
        }
        .status-pending { background: #ff9800; color: white; }
        .status-confirmed { background: #2196f3; color: white; }
        .status-ready { background: #4caf50; color: white; }
        .status-picked_up { background: #9e9e9e; color: white; }
        .form-inline {
            display: inline-block;
        }
        .add-product-form {
            background: #f9f9f9;
            padding: 1rem;
            margin-top: 1rem;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>🍲 Admin Dashboard</h1>
        <p>Manage Mama Jude's Food Shop</p>
    </div>
    
    <div class="admin-nav">
        <a href="/admin/dashboard">Dashboard</a>
        <a href="/">View Store</a>
        <a href="/admin/logout">Logout</a>
    </div>
    
    <div class="admin-container">
        <!-- Recent Orders -->
        <div class="section">
            <h2>Recent Orders</h2>
            <table>
                <thead>
                    <tr><th>Order #</th><th>Customer</th><th>Total</th><th>Status</th><th>Pickup Time</th><th>Action</th></tr>
                </thead>
                <tbody>
                    <% orders.forEach(order => { %>
                        <tr>
                            <td><%= order.order_number %></td>
                            <td><%= order.customer_name %><br><small><%= order.customer_phone %></small></td>
                            <td>₦<%= order.total_amount %></td>
                            <td>
                                <span class="status-badge status-<%= order.status %>">
                                    <%= order.status %>
                                </span>
                            </td>
                            <td><%= order.pickup_time %></td>
                            <td>
                                <form method="POST" action="/admin/order/<%= order.id %>/status" class="form-inline">
                                    <select name="status" onchange="this.form.submit()">
                                        <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                        <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                                        <option value="ready" <%= order.status === 'ready' ? 'selected' : '' %>>Ready</option>
                                        <option value="picked_up" <%= order.status === 'picked_up' ? 'selected' : '' %>>Picked Up</option>
                                    </select>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        
        <!-- Products Management -->
        <div class="section">
            <h2>Products</h2>
            <table>
                <thead>
                    <tr><th>Name</th><th>Price</th><th>Stock</th><th>Status</th><th>Update</th></tr>
                </thead>
                <tbody>
                    <% products.forEach(product => { %>
                        <tr>
                            <td><%= product.name %></td>
                            <td>₦<%= product.price %></td>
                            <td><%= product.stock_quantity %></td>
                            <td><%= product.is_available ? '✓ Available' : '✗ Unavailable' %></td>
                            <td>
                                <form method="POST" action="/admin/product/<%= product.id %>/update">
                                    <input type="number" name="price" value="<%= product.price %>" step="100" style="width:80px">
                                    <input type="number" name="stock_quantity" value="<%= product.stock_quantity %>" style="width:60px">
                                    <select name="is_available">
                                        <option value="true" <%= product.is_available ? 'selected' : '' %>>Available</option>
                                        <option value="false" <%= !product.is_available ? 'selected' : '' %>>Unavailable</option>
                                    </select>
                                    <button type="submit">Update</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
            
            <details class="add-product-form">
                <summary>➕ Add New Product</summary>
                <form method="POST" action="/admin/product">
                    <input type="text" name="name" placeholder="Product Name" required>
                    <textarea name="description" placeholder="Description"></textarea>
                    <input type="number" name="price" placeholder="Price" step="100" required>
                    <input type="number" name="stock_quantity" placeholder="Stock" required>
                    <input type="text" name="unit" placeholder="Unit (e.g., 500g pack, 1kg)" required>
                    <select name="category_id" required>
                        <option value="1">Soups & Powders</option>
                        <option value="2">Vegetables</option>
                        <option value="3">Swallows</option>
                        <option value="4">Grains & Rice</option>
                        <option value="5">Oils</option>
                        <option value="6">Seasonings</option>
                        <option value="7">Protein</option>
                    </select>
                    <button type="submit">Add Product</button>
                </form>
            </details>
        </div>
    </div>
    
    <div class="footer">
        <p> Admin Panel</p>
    </div>
</body>
</html>